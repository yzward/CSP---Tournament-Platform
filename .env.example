# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL="your_supabase_url"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_supabase_anon_key"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# App Configuration
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
APP_URL="https://your-app.vercel.app"

# Challonge API Key
CHALLONGE_API_KEY="your_challonge_api_key"

# Discord OAuth Configuration
DISCORD_CLIENT_ID="your_discord_client_id"
DISCORD_CLIENT_SECRET="your_discord_client_secret"
DISCORD_GUILD_ID="your_discord_guild_id"
DISCORD_ALLOWED_ROLE_IDS="role_id1,role_id2"
DISCORD_WEBHOOK_URL="your_discord_webhook_url"
NEXT_PUBLIC_DISCORD_INVITE_URL="https://discord.gg/your-invite"

# Optional Integrations
STARTGG_API_KEY="your_startgg_api_key"
WORDPRESS_URL="your_wordpress_site_url"
WORDPRESS_USERNAME="your_wordpress_username"
WORDPRESS_APP_PASSWORD="your_wordpress_app_password"
